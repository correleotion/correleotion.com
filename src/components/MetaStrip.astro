---
const cells = [
  { label: 'ROLE', value: 'AI / ML Engineer' },
  { label: 'FOCUS', value: 'CV · Statistics' },
  { label: 'STACK', value: 'Python · PyTorch' },
  { label: 'EDU', value: 'Thammasat U.' },
];
---

<div class="meta-strip">
  {
    cells.map((c) => (
      <div class="meta-cell">
        <div class="meta-cell__label">{c.label}</div>
        <div class="meta-cell__value">{c.value}</div>
      </div>
    ))
  }
</div>
