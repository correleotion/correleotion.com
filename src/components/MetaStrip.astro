---
const cells = [
  { label: 'ROLE', value: 'AI / ML Engineer' },
  { label: 'FOCUS', value: 'CV · Statistics' },
  { label: 'STACK', value: 'Python · PyTorch' },
  { label: 'EDU', value: 'Thammasat U.' },
];
---

<div class="meta-strip">
  {
    cells.map((c, i) => (
      <div class="meta-cell">
        <div class="meta-cell__label" data-cms={`meta.${i + 1}.label`}>{c.label}</div>
        <div class="meta-cell__value" data-cms={`meta.${i + 1}.value`}>{c.value}</div>
      </div>
    ))
  }
</div>
