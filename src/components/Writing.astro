---
// Writing list — edit this array to add posts. `draft: true` renders the muted style.
const posts = [
  { date: '2026.05', title: 'Training a leaf-disease classifier on a tiny dataset', href: '#' },
  { date: '2026.02', title: 'What 14 seasons of F1 data say about qualifying', href: '#' },
  { draft: true, title: 'Add your own post — replace these placeholders', href: '#' },
];
---

<section id="writing" class="section">
  <div class="section__head section__head--split">
    <div class="section__head-group">
      <span class="section__num">07</span>
      <h2 class="section__title">Writing</h2>
    </div>
    <span class="section__aside">notes &amp; build logs</span>
  </div>
  <div class="timeline">
    {
      posts.map((post) =>
        post.draft ? (
          <a href={post.href} class="writing-row">
            <span class="writing-row__date">draft</span>
            <span class="writing-row__title writing-row__title--draft">{post.title}</span>
            <span class="writing-row__arrow writing-row__arrow--faint">→</span>
          </a>
        ) : (
          <a href={post.href} class="writing-row">
            <span class="writing-row__date">{post.date}</span>
            <span class="writing-row__title">{post.title}</span>
            <span class="writing-row__arrow">→</span>
          </a>
        )
      )
    }
  </div>
</section>
