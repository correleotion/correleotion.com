---
// Writing list — edit this array to add posts. `draft: true` renders the muted style.
const posts = [
  { date: '2026.05', titleKey: 'w1', href: '#' },
  { date: '2026.02', titleKey: 'w2', href: '#' },
  { draft: true, titleKey: 'w3', href: '#' },
];
---

<section id="writing" class="section">
  <div class="section__head section__head--split">
    <div class="section__head-group">
      <span class="section__num">07</span>
      <h2 class="section__title" data-i18n="writingH">Writing</h2>
    </div>
    <span class="section__aside" data-i18n="wNotes">notes &amp; build logs</span>
  </div>
  <div class="timeline">
    {
      posts.map((post) =>
        post.draft ? (
          <a href={post.href} class="writing-row">
            <span class="writing-row__date" data-i18n="draft">draft</span>
            <span class="writing-row__title writing-row__title--draft" data-i18n={post.titleKey} />
            <span class="writing-row__arrow writing-row__arrow--faint">→</span>
          </a>
        ) : (
          <a href={post.href} class="writing-row">
            <span class="writing-row__date">{post.date}</span>
            <span class="writing-row__title" data-i18n={post.titleKey} />
            <span class="writing-row__arrow">→</span>
          </a>
        )
      )
    }
  </div>
</section>
