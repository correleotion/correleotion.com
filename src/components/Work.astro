---

<section id="work" class="section">
  <div class="section__head section__head--split">
    <div class="section__head-group">
      <span class="section__num">04</span>
      <h2 class="section__title">Selected Projects</h2>
    </div>
    <a href="https://github.com/correleotion?tab=repositories" class="link-muted">all repos ↗</a>
  </div>

  <!-- featured -->
  <a href="https://github.com/correleotion/Durian-Leaf-Disease-Classification" class="card-featured">
    <div class="card-featured__head">
      <span class="card-featured__tag">★ FEATURED</span>
      <span class="card-featured__lang">Jupyter / PyTorch</span>
    </div>
    <h3 class="card-featured__title">Durian Leaf Disease Classification</h3>
    <p class="card-featured__desc">
      A deep-learning image classifier that identifies durian leaf diseases from photos — built to
      support early detection for growers. Covers the full loop: dataset curation, augmentation,
      CNN training, and evaluation in a reproducible notebook.
    </p>
    <div class="tag-row">
      <span class="tag--invert">Computer Vision</span>
      <span class="tag--invert">CNN</span>
      <span class="tag--invert">Image Augmentation</span>
    </div>
  </a>

  <!-- grid -->
  <div class="card-grid">
    {
      projects.map((p) => (
        <a href={p.href} class="card">
          <div class="card__head">
            <span class="card__num">{p.num}</span>
            <span class="card__lang">{p.lang}</span>
          </div>
          <h3 class="card__title">{p.title}</h3>
          <p class="card__desc">{p.desc}</p>
          <div class="tag-row">
            {p.tags.map((t) => (
              <span class="tag">{t}</span>
            ))}
          </div>
        </a>
      ))
    }
  </div>
</section>
