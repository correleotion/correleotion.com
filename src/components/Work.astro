// Project grid — edit this array to add/remove/reorder cards.
const projects = [
  {
    num: '02',
    href: 'https://github.com/correleotion/Statistical-Analysis-of-Performance-Factors-in-Formula-1-2010-2024-',
    lang: 'Python · Stats',
    title: 'F1 Performance Factor Analysis',
    desc: 'Statistical study of what drives results in Formula 1 across the 2010–2024 seasons — regression, correlation, and visual storytelling.',
    tags: ['Regression', 'Data Viz'],
  },
  {
    num: '03',
    href: 'https://github.com/correleotion/Data-Visualization-Using-Python-Project',
    lang: 'Python · Viz',
    title: 'Data Visualization Project',
    desc: "A study in turning raw datasets into clear, honest visuals — exploring chart design, distributions, and narrative with Python's plotting stack.",
    tags: ['Matplotlib', 'Pandas'],
  },
  {
    num: '04',
    href: 'https://github.com/correleotion/MP-Asset-Scanner',
    lang: 'Python · Tool',
    title: 'MP Asset Scanner',
    desc: 'A Python utility that scans and inventories assets automatically — built to replace a slow, manual process with a repeatable script.',
    tags: ['Automation', 'CLI'],
  },
  {
    num: '05',
    href: 'https://github.com/correleotion/unbuy',
    lang: 'TypeScript',
    title: 'unbuy',
    desc: 'A TypeScript web app exploring product and interface ideas — a change of pace from notebooks, into shipping something interactive.',
    tags: ['TypeScript', 'Web'],
  },
