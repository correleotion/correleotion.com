---
// Tech stack columns — edit this array to change the grid.
const columns = [
  { label: 'LANGUAGES', items: ['Python', 'TypeScript', 'SQL', 'R'] },
  { label: 'ML / AI', items: ['PyTorch', 'scikit-learn', 'CNNs', 'Computer Vision'] },
  { label: 'DATA', items: ['Pandas / NumPy', 'Matplotlib', 'Seaborn', 'Jupyter'] },
  { label: 'TOOLS', items: ['Git / GitHub', 'VS Code', 'Linux', 'Notebooks'] },
];
---

<section id="stack" class="section">
  <div class="section__head">
    <span class="section__num">03</span>
    <h2 class="section__title">Stack</h2>
  </div>
  <div class="stack-grid">
    {
      columns.map((col) => (
        <div class="stack-cell">
          <div class="stack-cell__label">{col.label}</div>
          <div class="stack-cell__items" set:html={col.items.join('<br>')} />
        </div>
      ))
    }
  </div>
</section>
