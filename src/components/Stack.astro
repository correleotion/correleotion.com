---
// Tech stack columns — edit this array to change the grid.
// Icons are monochrome SVGs in public/img/stack/ (dark mode inverts them via CSS).
const columns = [
  {
    label: 'LANGUAGES',
    items: [
      { name: 'Python', icon: 'python' },
      { name: 'TypeScript', icon: 'typescript' },
      { name: 'SQL', icon: 'database' },
      { name: 'R', icon: 'r' },
    ],
  },
  {
    label: 'ML / AI',
    items: [
      { name: 'PyTorch', icon: 'pytorch' },
      { name: 'scikit-learn', icon: 'scikitlearn' },
      { name: 'CNNs', icon: 'network' },
      { name: 'Computer Vision', icon: 'eye' },
    ],
  },
  {
    label: 'DATA',
    items: [
      { name: 'Pandas', icon: 'pandas' },
      { name: 'NumPy', icon: 'numpy' },
      { name: 'Matplotlib', icon: 'matplotlib' },
      { name: 'Seaborn', icon: 'seaborn' },
      { name: 'Jupyter', icon: 'jupyter' },
    ],
  },
  {
    label: 'TOOLS',
    items: [
      { name: 'Git', icon: 'git' },
      { name: 'GitHub', icon: 'github' },
      { name: 'VS Code', icon: 'vscode' },
      { name: 'Linux', icon: 'linux' },
      { name: 'Notebooks', icon: 'notebook' },
    ],
  },
];
---

<section id="stack" class="section">
  <div class="section__head">
    <span class="section__num">03</span>
    <h2 class="section__title">Stack</h2>
  </div>
  <div class="stack-grid">
    {
      columns.map((col) => (
        <div class="stack-cell">
          <div class="stack-cell__label">{col.label}</div>
          <div class="stack-cell__items">
            {col.items.map((item) => (
              <div class="stack-item">
                <img src={`/img/stack/${item.icon}.svg`} alt="" width="15" height="15" loading="lazy" />
                <span>{item.name}</span>
              </div>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>
